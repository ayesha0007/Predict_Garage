{
  "version": 2,
  "builds": [
    {
      "src": "garage_back/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "garage_front/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "garage_back/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "/garage_front/$1"
    },
    {
      "src": "/",
      "dest": "/garage_front/index.html"
    }
  ]
}